{
  "name": "avignon-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Planificateur de booking optimal pour le Festival Off d'Avignon",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "scrape": "node scraper/scrape.mjs",
    "scrape:favorites": "node scraper/addFavorites.mjs",
    "scrape:venues": "node scraper/venues.mjs",
    "icons": "node scripts/icons.mjs",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
